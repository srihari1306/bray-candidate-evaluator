# ──────────────────────────────────────────────────
# Candidate Evaluator - Environment Configuration
# ──────────────────────────────────────────────────

# ─── Application ───
APP_NAME=Candidate Evaluator
APP_VERSION=1.0.0
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001

# ─── Azure AD / Entra ID ───
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_AD_AUDIENCE=api://your-client-id

# ─── Azure OpenAI ───
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-key
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# ─── Azure AI Search ───
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your-search-key
AZURE_SEARCH_INDEX_NAME=resume-index

# ─── Azure AI Document Intelligence ───
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://your-doc-intel.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=your-doc-intel-key

# ─── Azure Blob Storage ───
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER=resumes

# ─── Azure Key Vault ───
AZURE_KEYVAULT_URL=https://your-keyvault.vault.azure.net/

# ─── Azure Monitor ───
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# ─── SharePoint ───
SHAREPOINT_SITE_URL=https://your-org.sharepoint.com/sites/hr
SHAREPOINT_SITE_ID=your-site-id
SHAREPOINT_DRIVE_ID=your-drive-id
SHAREPOINT_FOLDER_PATH=Resumes

# ─── Processing ───
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=100
MAX_CONCURRENT_PROCESSING=5
EMBEDDING_BATCH_SIZE=16
MAX_RETRIES=3

# ─── Gmail SMTP Email ───
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
MOCK_EMAIL=true

# ─── Persistence ───
INTERVIEWS_JSON_PATH=data/interviews.json

# ─── Azure Speech Service ───
AZURE_SPEECH_KEY=your_speech_service_key
AZURE_SPEECH_REGION=eastus

# ─── Static Teams Meeting Link ───
TEAMS_STATIC_MEETING_URL=https://teams.microsoft.com/l/meetup-join/...
INTERVIEW_PANEL_BASE_URL=http://localhost:3001

# ─── Blob Container for Recordings ───
AZURE_BLOB_RECORDINGS_CONTAINER=interview-recordings

# ─── Interview Questions (JSON array) ───
INTERVIEW_QUESTIONS=["Tell me about yourself.","Describe a challenging project you worked on.","Why are you interested in this role?"]

# ─── Session Token Secret ───
INTERVIEW_SESSION_SECRET=a_long_random_secret_string
